# Shared
APP_ENV=development
APP_NAME=TruthLens AI

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
FRONTEND_URL=http://localhost:5173

# Backend
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
EMAIL_TOKEN_MINUTES=60
PASSWORD_RESET_MINUTES=30
UPLOAD_STORAGE_DIR=storage/uploads
UPLOAD_URL_PREFIX=/storage/uploads
MAX_IMAGE_UPLOAD_MB=20

# MongoDB Atlas
# Replace with your Atlas connection string in .env
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/truthlens_ai?retryWrites=true&w=majority
MONGODB_DATABASE=truthlens_ai
